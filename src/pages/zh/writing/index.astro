    comingSoon: false
  },
  {
    title: "AI 学习笔记 — 4月12日",
    date: "2026-04-12",
    type: "learning-log",
    slug: "0412-ai-notes",
    excerpt: "安静的一天。有时候让想法沉淀一下也是好的。",
    comingSoon: false
  },
  {
    title: "AI 学习笔记 — 4月11日",
    date: "2026-04-11",
    type: "learning-log",
    slug: "0411-ai-notes",
    excerpt: "顾问式 agent 协调：廉价执行器 + 高昂顾问。Haiku + Opus 组合使 BrowseComp 得分比单独使用 Haiku 高出一倍以上。",
    comingSoon: false
  },
  {
    title: "AI 学习笔记 — 4月10日",
    date: "2026-04-10",
