---
import Layout from '../../../layouts/Layout.astro';
import bookData from '../../../data/book-zh.json';

const lang = 'zh';
const title = "禅宗、儒家、斯多葛、阿德勒";
const subtitle = "东西方四大思想的对话与交汇";

// Helper: split fullTitle "第四章：沉稳——如山之静" into eyebrow "第四章" + title "沉稳——如山之静"
function splitTitle(num: number, fullTitle: string): { eyebrow: string; main: string } {
  if (num === 0) return { eyebrow: '前言', main: '前言' };
  if (num === 11) {
    // "结语：东西方智慧的现代回响"
    const idx = fullTitle.search(/[:：]/);
    if (idx >= 0) return { eyebrow: '结语', main: fullTitle.slice(idx + 1).trim() };
    return { eyebrow: '结语', main: fullTitle };
  }
  // "第N章：xxx" or "第N章:xxx"
  const m = fullTitle.match(/^(第[一二三四五六七八九十]+章)[:：](.*)$/);
  if (m) return { eyebrow: m[1], main: m[2].trim() };
  return { eyebrow: `第${num}章`, main: fullTitle };
}
---

<Layout title={title} lang={lang}>
  <div class="reading-progress" id="reading-progress"></div>

  <section class="book-hero">
    <div class="hero-inner">
      <div class="cover-wrap">
        <img src="/images/book/cover-zh.jpg" alt="书籍封面" />
      </div>
      <div class="hero-text">
        <p class="kicker">书籍</p>
        <h1>{title}</h1>
        <p class="subtitle">{subtitle}</p>
        <p class="meta">王正剑 · 2026 · 12 章 · 约 90 分钟阅读</p>
        <div class="hero-actions">
          <a href="#chapter-00" class="cta-primary">开始阅读 ↓</a>
          <a href="/writing/where-sages-agree/" class="cta-secondary">English</a>
        </div>
      </div>
    </div>
  </section>

  <div class="book-reader" id="book-reader">
    <button class="sidebar-open" id="sidebar-open" aria-label="打开目录">☰&nbsp; 目录</button>

    <aside class="book-sidebar" id="book-sidebar">
      <div class="sidebar-head">
        <span class="sidebar-title">目录</span>
        <button class="sidebar-close" id="sidebar-close" aria-label="收起目录">×</button>
      </div>
      <nav class="chapter-nav">
        {bookData.map((ch) => (
          <div class="chapter-group">
            <a href={`#chapter-${String(ch.num).padStart(2, '0')}`} data-target={`chapter-${String(ch.num).padStart(2, '0')}`} class="chapter-link">
              <span class="chapter-num">{ch.num}</span>
              <span class="chapter-name">{ch.shortTitle}</span>
            </a>
            {ch.sections && ch.sections.length > 0 && (
              <ul class="section-list">
                {ch.sections.map((s) => (
                  <li>
                    <a href={`#${s.id}`} data-target={s.id} class="section-link">{s.title}</a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </nav>
    </aside>

    <main class="book-content">
      {bookData.map((ch) => {
        const { eyebrow, main } = splitTitle(ch.num, ch.fullTitle);
        return (
          <section class="chapter" id={`chapter-${String(ch.num).padStart(2, '0')}`}>
            <p class="chapter-eyebrow">{eyebrow}</p>
            <h2 class="chapter-title">{main}</h2>
            <hr class="chapter-divider" />
            <div class="chapter-body" set:html={ch.html} />
          </section>
        );
      })}
    </main>
  </div>

  <button class="back-to-top" id="back-to-top" aria-label="回到顶部">↑</button>
</Layout>

<script>
  const progressBar = document.getElementById('reading-progress');
  const updateProgress = () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    if (progressBar) progressBar.style.width = pct + '%';
  };
  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  const reader = document.getElementById('book-reader');
  const closeBtn = document.getElementById('sidebar-close');
  const openBtn = document.getElementById('sidebar-open');
  const STORAGE_KEY = 'book-sidebar-collapsed';

  const isMobile = () => window.innerWidth < 900;

  const setCollapsed = (collapsed) => {
    if (!reader) return;
    reader.classList.toggle('sidebar-collapsed', collapsed);
    if (!isMobile()) {
      try { localStorage.setItem(STORAGE_KEY, collapsed ? '1' : '0'); } catch (e) {}
    }
  };

  if (isMobile()) {
    setCollapsed(true);
  } else {
    try {
      if (localStorage.getItem(STORAGE_KEY) === '1') setCollapsed(true);
    } catch (e) {}
  }

  if (closeBtn) closeBtn.addEventListener('click', () => setCollapsed(true));
  if (openBtn) openBtn.addEventListener('click', () => setCollapsed(false));

  document.querySelectorAll('.chapter-link').forEach((link) => {
    link.addEventListener('click', () => {
      if (isMobile()) setCollapsed(true);
    });
  });

  let lastIsMobile = isMobile();
  window.addEventListener('resize', () => {
    const nowMobile = isMobile();
    if (nowMobile !== lastIsMobile) {
      lastIsMobile = nowMobile;
      if (nowMobile) {
        setCollapsed(true);
      } else {
        try {
          setCollapsed(localStorage.getItem(STORAGE_KEY) === '1');
        } catch (e) {
          setCollapsed(false);
        }
      }
    }
  });

  const navLinks = Array.from(document.querySelectorAll('.chapter-link, .section-link'));
  const linkMap = new Map();
  navLinks.forEach((l) => {
    const target = l.getAttribute('data-target');
    if (target) linkMap.set(target, l);
  });

  const visible = new Set();
  const updateActive = () => {
    let active = null;
    let minTop = Infinity;
    visible.forEach((id) => {
      const el = document.getElementById(id);
      if (el) {
        const top = el.getBoundingClientRect().top;
        if (top < minTop) { minTop = top; active = id; }
      }
    });
    navLinks.forEach((l) => l.classList.remove('active', 'parent-active'));
    if (active && linkMap.has(active)) {
      const link = linkMap.get(active);
      link.classList.add('active');
      if (active.startsWith('ch') && active.includes('-s')) {
        const chNum = active.slice(2, 4);
        const parent = linkMap.get('chapter-' + chNum);
        if (parent) parent.classList.add('parent-active');
        const aside = document.getElementById('book-sidebar');
        if (aside && link instanceof HTMLElement) {
          const linkRect = link.getBoundingClientRect();
          const asideRect = aside.getBoundingClientRect();
          if (linkRect.top < asideRect.top || linkRect.bottom > asideRect.bottom) {
            link.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
          }
        }
      }
    }
  };

  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) visible.add(e.target.id);
      else visible.delete(e.target.id);
    });
    updateActive();
  }, { rootMargin: '-15% 0px -70% 0px', threshold: 0 });

  document.querySelectorAll('.chapter').forEach((ch) => obs.observe(ch));
  document.querySelectorAll('.chapter-body h2[id]').forEach((h) => obs.observe(h));

  const backTop = document.getElementById('back-to-top');
  const updateBackTop = () => {
    if (!backTop) return;
    if (window.scrollY > window.innerHeight) backTop.classList.add('visible');
    else backTop.classList.remove('visible');
  };
  window.addEventListener('scroll', updateBackTop, { passive: true });
  if (backTop) backTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  updateBackTop();
</script>

<style>
  .reading-progress {
    position: fixed; top: 0; left: 0; height: 2px; width: 0%;
    background: var(--color-accent); z-index: 200;
    transition: width 100ms linear;
  }

  .book-hero {
    padding: 4rem 1.5rem 5rem;
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
    border-bottom: 1px solid var(--color-border);
  }
  .hero-inner {
    max-width: 960px; margin: 0 auto;
    display: grid; grid-template-columns: 240px 1fr;
    gap: 3.5rem; align-items: center;
  }
  .cover-wrap {
    aspect-ratio: 9 / 16;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 24px 60px -12px rgba(28, 25, 23, 0.25), 0 8px 24px -8px rgba(28, 25, 23, 0.15);
  }
  .cover-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .hero-text .kicker {
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .hero-text h1 {
    font-family: 'Songti SC', 'Source Han Serif SC', 'Noto Serif CJK SC', var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 2.85rem);
    line-height: 1.2; letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }
  .hero-text .subtitle {
    font-family: 'Songti SC', 'Source Han Serif SC', var(--font-serif);
    font-size: 1.2rem; color: var(--color-text-muted);
    margin-bottom: 1.5rem; line-height: 1.5;
  }
  .hero-text .meta {
    font-size: 0.9rem; color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .cta-primary {
    display: inline-block; background: var(--color-text);
    color: var(--color-hero-text); padding: 0.9rem 1.6rem;
    border-radius: var(--radius); font-weight: 600;
    font-size: 0.95rem; transition: all var(--transition);
  }
  .cta-primary:hover {
    background: var(--color-accent); color: #fff;
    transform: translateY(-2px);
  }
  .cta-secondary {
    display: inline-block; border: 1px solid var(--color-border);
    color: var(--color-text-muted); padding: 0.9rem 1.6rem;
    border-radius: var(--radius); font-weight: 500;
    font-size: 0.95rem; transition: all var(--transition);
  }
  .cta-secondary:hover {
    border-color: var(--color-accent); color: var(--color-accent);
  }

  .book-reader {
    max-width: 1100px; margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    display: grid; grid-template-columns: 220px 1fr;
    gap: 4rem; position: relative;
    transition: grid-template-columns 250ms ease;
  }
  .book-sidebar {
    position: sticky; top: calc(var(--nav-height) + 2rem);
    align-self: start;
    max-height: calc(100vh - var(--nav-height) - 4rem);
    overflow-y: auto; padding: 1.25rem 0;
    transition: opacity 200ms ease;
  }
  .sidebar-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.75rem;
  }
  .sidebar-title {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--color-text-light);
  }
  .sidebar-close {
    background: none; border: none; cursor: pointer;
    color: var(--color-text-light); font-size: 1.4rem; line-height: 1;
    padding: 0 0.25rem; transition: color var(--transition);
  }
  .sidebar-close:hover { color: var(--color-text); }

  .chapter-nav { display: flex; flex-direction: column; gap: 0.5rem; }
  .chapter-group { display: flex; flex-direction: column; }
  .chapter-link {
    display: flex; align-items: baseline; gap: 0.7rem;
    padding: 0.5rem 0.75rem;
    color: var(--color-text); font-size: 0.9rem;
    font-weight: 500; line-height: 1.45;
    border-left: 2px solid transparent;
    border-radius: 0 var(--radius) var(--radius) 0;
    transition: all var(--transition);
  }
  .chapter-link:hover {
    background: var(--color-accent-light);
    color: var(--color-accent);
  }
  .chapter-link.active,
  .chapter-link.parent-active {
    border-left-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-light);
    font-weight: 600;
  }
  .chapter-link .chapter-num {
    font-size: 0.7rem; color: var(--color-text-light);
    font-variant-numeric: tabular-nums; min-width: 1rem;
    flex-shrink: 0; margin-top: 0.15rem;
  }
  .chapter-link:hover .chapter-num,
  .chapter-link.active .chapter-num,
  .chapter-link.parent-active .chapter-num {
    color: var(--color-accent);
  }
  .chapter-link .chapter-name { flex: 1; }

  .section-list {
    list-style: none;
    padding: 0.15rem 0 0.25rem;
    margin: 0 0 0.1rem 0;
    border-left: 1px solid var(--color-border);
    margin-left: 0.85rem;
  }
  .section-list li { margin: 0; }
  .section-link {
    display: block;
    padding: 0.3rem 0.75rem 0.3rem 0.95rem;
    color: var(--color-text-light);
    font-size: 0.82rem;
    line-height: 1.45;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: all var(--transition);
  }
  .section-link:hover {
    color: var(--color-text);
    background: var(--color-accent-light);
  }
  .section-link.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    background: var(--color-accent-light);
    font-weight: 500;
  }

  .sidebar-open {
    position: fixed; top: calc(var(--nav-height) + 1rem); left: 1rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.55rem 0.85rem; cursor: pointer;
    color: var(--color-text-muted);
    font-size: 0.85rem; font-weight: 500; line-height: 1;
    z-index: 90; opacity: 0; pointer-events: none;
    transition: opacity 200ms ease;
    box-shadow: 0 2px 8px rgba(28, 25, 23, 0.06);
    font-family: var(--font-sans);
  }
  .sidebar-open:hover { color: var(--color-accent); border-color: var(--color-accent); }

  .book-reader.sidebar-collapsed { grid-template-columns: 1fr; }
  .book-reader.sidebar-collapsed .book-sidebar { display: none; }
  .book-reader.sidebar-collapsed .sidebar-open {
    opacity: 1; pointer-events: auto;
  }

  .book-content { min-width: 0; }
  .chapter {
    padding: 4rem 0;
    border-bottom: 1px solid var(--color-border);
    scroll-margin-top: calc(var(--nav-height) + 1rem);
  }
  .chapter:first-child { padding-top: 0; }
  .chapter:last-child { border-bottom: none; }
  .chapter-eyebrow {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }
  .chapter-title {
    font-family: 'Songti SC', 'Source Han Serif SC', 'Noto Serif CJK SC', var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    line-height: 1.3; letter-spacing: -0.005em;
    margin-bottom: 1.25rem;
  }
  .chapter-divider {
    border: none; border-top: 1px solid var(--color-border);
    width: 60px; margin-bottom: 2.5rem;
  }
  .chapter-body {
    font-family: 'Songti SC', 'Source Han Serif SC', 'Noto Serif CJK SC', var(--font-serif);
    font-size: 1.075rem; line-height: 1.95;
    color: var(--color-text); max-width: 680px;
  }
  .chapter-body :global(h2) {
    font-family: 'Songti SC', 'Source Han Serif SC', var(--font-serif);
    font-size: 1.35rem; margin-top: 3rem; margin-bottom: 1.25rem;
    letter-spacing: -0.005em; color: var(--color-text);
  }
  .chapter-body :global(h3) {
    font-family: 'Songti SC', 'Source Han Serif SC', var(--font-serif);
    font-size: 1.15rem; margin-top: 2.25rem; margin-bottom: 1rem;
    color: var(--color-text);
  }
  .chapter-body :global(p) {
    margin-bottom: 1.4rem; color: var(--color-text-muted);
  }
  .chapter-body :global(strong) {
    color: var(--color-text); font-weight: 600;
  }
  .chapter-body :global(em) { font-style: italic; }
  .chapter-body :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding: 0.25rem 0 0.25rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }
  .chapter-body :global(ul),
  .chapter-body :global(ol) {
    padding-left: 1.5rem; margin-bottom: 1.4rem;
  }
  .chapter-body :global(li) {
    margin-bottom: 0.6rem; color: var(--color-text-muted);
  }
  .chapter-body :global(hr) {
    border: none; border-top: 1px solid var(--color-border);
    margin: 2.5rem auto; width: 80px;
  }

  .back-to-top {
    position: fixed; bottom: 2rem; right: 2rem;
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted); cursor: pointer;
    font-size: 1.1rem; line-height: 1;
    box-shadow: 0 4px 16px rgba(28, 25, 23, 0.08);
    opacity: 0; pointer-events: none;
    transition: all var(--transition); z-index: 90;
  }
  .back-to-top.visible { opacity: 1; pointer-events: auto; }
  .back-to-top:hover {
    background: var(--color-accent); color: #fff;
    border-color: var(--color-accent);
    transform: translateY(-3px);
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr; gap: 2rem; text-align: center;
    }
    .cover-wrap { max-width: 220px; margin: 0 auto; }
    .hero-actions { justify-content: center; }
    .book-reader {
      grid-template-columns: 1fr; gap: 0;
      padding: 2rem 1.25rem 4rem;
    }
    .book-reader:not(.sidebar-collapsed) .book-sidebar {
      display: block;
      position: fixed; top: 0; left: 0;
      width: 280px; max-width: 85vw;
      height: 100vh; max-height: 100vh;
      background: var(--color-bg);
      border-right: 1px solid var(--color-border);
      padding: calc(var(--nav-height) + 1rem) 1rem 1rem;
      z-index: 95;
      box-shadow: 4px 0 24px rgba(0, 0, 0, 0.12);
      overflow-y: auto;
    }
  }
</style>
